{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://780m-llm-perf-lab/schemas/run_v0.schema.json",
  "title": "Run Metadata Schema v0",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "timestamp_utc",
    "git_commit",
    "commandline",
    "backend",
    "workload",
    "system"
  ],
  "properties": {
    "schema_version": {
      "const": "run_v0"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "timestamp_utc": {
      "type": "string",
      "format": "date-time"
    },
    "git_commit": {
      "type": "string",
      "minLength": 1
    },
    "commandline": {
      "type": "string",
      "minLength": 1
    },
    "backend": {
      "type": "object",
      "required": [
        "name",
        "version"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "model": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "minLength": 8
        }
      },
      "additionalProperties": true
    },
    "workload": {
      "type": "object",
      "required": [
        "path",
        "sha256"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "minLength": 8
        }
      },
      "additionalProperties": true
    },
    "system": {
      "type": "object",
      "required": [
        "os_build",
        "cpu",
        "gpu",
        "ram_gb"
      ],
      "properties": {
        "os_build": {
          "type": "string",
          "minLength": 1
        },
        "driver": {
          "type": "string"
        },
        "cpu": {
          "type": "string",
          "minLength": 1
        },
        "gpu": {
          "type": "string",
          "minLength": 1
        },
        "ram_gb": {
          "type": "number",
          "minimum": 0
        }
      },
      "additionalProperties": true
    },
    "reproducibility": {
      "type": "object",
      "properties": {
        "commands": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
